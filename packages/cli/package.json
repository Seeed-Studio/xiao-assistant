{
  "name": "@seeedstudio/xiao-cli",
  "version": "0.0.1",
  "description": "XIAO CLI - Command-line tools for XIAO development assistance",
  "type": "module",
  "bin": {
    "xiao": "./dist/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup && cp -r web dist/web",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --fix",
    "lint:check": "eslint src",
    "format": "prettier --write src",
    "format:check": "prettier --check src",
    "clean": "rm -rf dist node_modules",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@inquirer/prompts": "^8.2.0",
    "@seeedstudio/xiao-sdk": "workspace:*",
    "commander": "^13.1.0",
    "express": "^5.2.1",
    "figlet": "^1.9.4",
    "open": "^10.1.0",
    "ora": "^9.0.0",
    "picocolors": "^1.1.1",
    "yaml": "^2.8.4"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^25.0.3",
    "tsup": "^8.4.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.14"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/seeedstudio/xiao-assistant.git",
    "directory": "packages/cli"
  },
  "keywords": [
    "xiao",
    "cli",
    "seeed-studio",
    "iot",
    "development-tools"
  ],
  "author": "Seeed Studio",
  "license": "MIT"
}